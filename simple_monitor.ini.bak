[layout]
; Horizontal padding inside the overlay content area.
content_padding_x=8

; Default gap between the main metric columns.
column_gap=24

; Optional per-column overrides. Use -1 to fall back to column_gap.
gap_after_network=10
gap_after_system=14
gap_after_disk=12

; Horizontal offset between the overlay and the tray-side anchor.
offset_right=-52

; Base DirectWrite font size in logical pixels before DPI scaling.
font_size=13
key_font_size=14

; Network arrow glyph set: thin, triangle, heavy, chevron.
network_arrow_style=thin
network_arrow_font_size=17
network_arrow_gap=3
debug_log=0

; Show the compact CAP/INS/NUM status widget after the disk column.
show_key_widget=1
